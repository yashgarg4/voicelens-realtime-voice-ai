# Google Gemini API key — required for the Gemini Live voice pipeline.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional overrides (defaults shown in backend/config.py)
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview   # stable alt: gemini-2.0-flash-live-001
# GRADER_MODEL=gemini-3.5-flash                      # text model that scores answers
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# FRONTEND_ORIGIN=http://localhost:5173

# B2: re-transcribe each answer with the fine-tuned Whisper and show it in the
# UI. Needs torch+transformers+peft installed and the adapter in
# finetune/output/adapter. No-ops gracefully if torch isn't installed.
# ENABLE_FINETUNED_STT=true
